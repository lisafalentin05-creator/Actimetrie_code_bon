<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ADD8E6"
    tools:context=".Fragment1">

    <!-- Bouton Permissions BT (en haut à gauche) -->
    <Button
        android:id="@+id/buttonpermission"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="Permissions BT"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/buttonactivation" />

    <!-- Bouton Activer BT (en haut à droite) -->
    <Button
        android:id="@+id/buttonactivation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:text="Activer BT"
        android:enabled="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/buttonpermission"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Guideline verticale au milieu -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- ListView : colonne gauche -->
    <ListView
        android:id="@+id/listViewAppareils"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintTop_toBottomOf="@+id/buttonpermission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintBottom_toTopOf="@+id/btnAppareils" />

    <!-- Bouton Appareils associés -->
    <Button
        android:id="@+id/btnAppareils"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        android:text="Appareils associés"
        android:enabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintBottom_toTopOf="@+id/btnEffacer" />

    <!-- Bouton Effacer Liste -->
    <Button
        android:id="@+id/btnEffacer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:text="Effacer Liste"
        android:enabled="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintBottom_toTopOf="@+id/btnInit" /> />

    <!-- Bouton Initialiser (visible seulement après 1ère trame reçue) -->
    <Button
        android:id="@+id/btnInit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:text="Initialiser"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintBottom_toTopOf="@+id/btnStart" />

    <!-- Bouton C'est parti (visible seulement après INIT_OK) -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:text="C'est parti"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintBottom_toTopOf="@+id/btnPage1" />

    <!-- TextView code-barres : centré sur tout l'écran -->
    <TextView
        android:id="@+id/tvCodeBarre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="invisible"
        android:background="@drawable/bordure_codebarre"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TextView en bas -->
    <TextView
        android:id="@+id/textViewBas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text=""
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Barre de navigation 3 boutons en bas ── -->

    <!-- Guideline 1/3 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineNav1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.333" />

    <!-- Guideline 2/3 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineNav2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.666" />

    <!-- Bouton Page 1 -->
    <Button
        android:id="@+id/btnPage1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="48dp"
        android:text="Page 1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineNav1"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bouton Page 2 -->
    <Button
        android:id="@+id/btnPage2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="48dp"
        android:text="Page 2"
        app:layout_constraintStart_toStartOf="@+id/guidelineNav1"
        app:layout_constraintEnd_toStartOf="@+id/guidelineNav2"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bouton Page 3 -->
    <Button
        android:id="@+id/btnPage3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="48dp"
        android:text="Page 3"
        app:layout_constraintStart_toStartOf="@+id/guidelineNav2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>